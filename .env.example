# =============================================================================
# OneEmergence — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Never commit .env.local to version control.

# --- Supabase ---
# Project URL and keys from Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# --- Database (Supabase Postgres via pooler) ---
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres"

# --- AI Guide (Anthropic Claude) ---
ANTHROPIC_API_KEY=""

# --- Sentry (optional) ---
NEXT_PUBLIC_SENTRY_DSN=""
